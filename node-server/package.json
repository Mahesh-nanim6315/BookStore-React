{
  "name": "bookstore-node-server",
  "version": "1.0.0",
  "description": "Node.js server for BookStore application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "knex": "knex --knexfile knexfile.js",
    "migrate": "knex --knexfile knexfile.js migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.js migrate:rollback",
    "migrate:status": "knex --knexfile knexfile.js migrate:status",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "bookstore",
    "node",
    "express",
    "mysql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^6.8.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0"
  },
  "devDependencies": {
    "knex": "^3.2.9",
    "nodemon": "^3.0.1"
  }
}
